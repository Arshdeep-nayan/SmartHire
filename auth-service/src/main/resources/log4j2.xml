<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="DEBUG">

    <Appenders>

        <Console name="Console">
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </Console>

        <File
                name="File"
                fileName="/logs/auth-service.log">

            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>

        </File>

    </Appenders>

    <Loggers>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>

        <Logger
                name="com.smarthire"
                level="DEBUG"
                additivity="false">

            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>

        </Logger>

    </Loggers>

</Configuration>