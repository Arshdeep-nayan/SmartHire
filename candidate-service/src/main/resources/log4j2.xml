<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

    <Appenders>

        <Console name="Console">
            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </Console>

        <RollingFile
                name="File"
                fileName="/logs/candidate-service.log"
                filePattern="/logs/candidate-service-%d{yyyy-MM-dd}-%i.log.gz">

            <PatternLayout
                    pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>

            <Policies>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>

        </RollingFile>

    </Appenders>

    <Loggers>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>

        <Logger
                name="com.SmartHire"
                level="DEBUG"
                additivity="false">

            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>

        </Logger>

    </Loggers>

</Configuration>